# ---- Local model (Ollama, OpenAI-compatible API) ----
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=gemma3:1b
LOCAL_API_KEY=ollama

# ---- Harness-injected at evaluation time (set here only to mimic it in dev) ----
# FIREWORKS_API_KEY=fw-...
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# ALLOWED_MODELS=accounts/fireworks/models/a,accounts/fireworks/models/b

# ---- Dev fallback remote (used ONLY when FIREWORKS_* absent AND ALLOW_DEV_REMOTE set) ----
# Groq free tier is the daily driver until Fireworks credits land.
# ALLOW_DEV_REMOTE gates this path so it can never fire inside a submitted
# container (routing inference outside Fireworks = disqualification).
REMOTE_BASE_URL=https://api.groq.com/openai/v1
REMOTE_MODEL=llama-3.3-70b-versatile
REMOTE_API_KEY=your-groq-key-here
ALLOW_DEV_REMOTE=1

# ---- Router tuning ----
# LOCAL_FIRST_CATEGORIES=code_generation,logic   # try local first for these
# ESCALATE_CATEGORIES=factual                    # always go remote for these
# MODEL_SMALL= / MODEL_LARGE= / MODEL_CODE=      # force tier choices
# TIME_BUDGET_SECONDS=540
# LOCAL_CONCURRENCY=2
# REQUEST_TIMEOUT=25
# INPUT_PATH=/input/tasks.json
# OUTPUT_PATH=/output/results.json
